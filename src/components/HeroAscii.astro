---

---

<div
  id="hero-ascii-container"
  class="w-full md:w-1/2 h-[400px] md:h-auto relative overflow-hidden bg-black/[0.02] dark:bg-white/[0.02] flex items-center justify-center cursor-crosshair"
>
  <pre id="hero-ascii" aria-hidden="true" class="hero-ascii-text"></pre>
</div>

<script>
  import { playSound } from "@lib/audio-manager";

  let frameId: number;
  let lastTime = 0;
  const FPS_LIMIT = 24;
  const FRAME_MIN_TIME = 1000 / FPS_LIMIT;
  const SWITCH_INTERVAL = 15000; // Switch animation every 15 seconds

  // Animation definitions
  interface TrailPoint {
    x: number;
    y: number;
    age: number;
    char: string;
    vx?: number;
    vy?: number;
  }

  interface Animation {
    name: string;
    prepare?: (time: number, cols: number, rows: number) => void;
    render: (
      x: number,
      y: number,
      time: number,
      dist: number,
      dx: number,
      dy: number,
      cols: number,
      rows: number,
    ) => number;
    updatePoint: (point: TrailPoint, cx: number, cy: number) => void;
    getClickParticles: (x: number, y: number) => Omit<TrailPoint, "char">[];
    _activeWaves?: { rx: number; ry: number; fade: number }[];
  }
  const ANIMATIONS: Animation[] = [
    {
      name: "wave",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        return (
          Math.sin(dist * 0.12 - time) * 0.6 +
          Math.cos(dx * 0.08 + time * 0.5) * 0.2 +
          Math.sin(dy * 0.08 + time * 0.5) * 0.2
        );
      },
      updatePoint: (p, cx, cy) => {
        const dx = p.x - cx;
        const dy = p.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 0) {
          p.x += (dx / dist) * 0.15;
          p.y += (dy / dist) * 0.15;
        }
        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.94;
          p.vy *= 0.94;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 12; i++) {
          const angle = (i / 12) * Math.PI * 2;
          particles.push({
            x,
            y,
            age: 1.5,
            vx: Math.cos(angle) * 1.2,
            vy: Math.sin(angle) * 1.2,
          });
        }
        return particles;
      },
    },
    {
      name: "cells",
      _activeWaves: [] as { rx: number; ry: number; fade: number }[],
      prepare(time, cols, rows) {
        this._activeWaves = [];
        const numWaves = 12; // More concurrent ripples
        const cycle = 5.0;
        for (let i = 0; i < numWaves; i++) {
          const t = time * 0.5 + i * (cycle / numWaves);
          const phase = t % cycle;
          const cycleIdx = Math.floor(t / cycle);
          const seed = i + cycleIdx * 987.65;

          const rx = Math.sin(seed * 7.4) * (cols * 0.45);
          const ry = Math.cos(seed * 4.2) * (rows * 0.45);
          // Smooth pulse in and out
          const fade = Math.pow(Math.sin((phase / cycle) * Math.PI), 2);

          this._activeWaves.push({ rx, ry, fade });
        }
      },
      render(x, y, time, dist, dx, dy, cols, rows) {
        let val = 0;
        if (!this._activeWaves) return 0;

        for (const w of this._activeWaves) {
          const adx = dx - w.rx;
          const ady = dy - w.ry;
          const d = Math.sqrt(adx * adx + ady * ady);
          // Tighter ripples (0.4) and faster movement (time * 4)
          val += Math.sin(d * 0.4 - time * 4) * w.fade * 0.3;
        }

        // Very subtle global movement
        val += Math.cos(dx * 0.1 + time) * 0.1;
        val += Math.sin(dy * 0.1 + time) * 0.1;

        return val - 0.1;
      },
      updatePoint: (p, cx, cy) => {
        // Fluid, multi-directional drift
        p.x += Math.sin(p.y * 0.1 + Date.now() * 0.001) * 0.1;
        p.y += Math.cos(p.x * 0.1 + Date.now() * 0.001) * 0.1;

        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.95;
          p.vy *= 0.95;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 12; i++) {
          const angle = (i / 12) * Math.PI * 2;
          particles.push({
            x,
            y,
            age: 1.5,
            vx: Math.cos(angle) * 1.2,
            vy: Math.sin(angle) * 1.2,
          });
        }
        return particles;
      },
    },
    {
      name: "vortex",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        const angle = Math.atan2(dy, dx);
        return (
          Math.sin(dist * 0.15 - time * 2 + angle * 3) * 0.7 +
          Math.cos(dx * 0.05 + time) * 0.3
        );
      },
      updatePoint: (p, cx, cy) => {
        const dx = p.x - cx;
        const dy = p.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        // Synchronized rotation (0.0133 matches the 2/3 ratio in the render function)
        const angle = Math.atan2(dy, dx) + 0.0133;
        const targetDist = dist * 0.985;
        p.x = cx + Math.cos(angle) * targetDist;
        p.y = cy + Math.sin(angle) * targetDist;
        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.92;
          p.vy *= 0.92;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 16; i++) {
          const angle = Math.random() * Math.PI * 2;
          // Reduced initial speed for click particles
          const speed = 0.3 + Math.random() * 0.7;
          particles.push({
            x,
            y,
            age: 1.8,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
          });
        }
        return particles;
      },
    },
    {
      name: "grid",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        return (
          Math.sin(x * 0.15 + time) * 0.4 +
          Math.cos(y * 0.15 + time) * 0.4 +
          Math.sin(dist * 0.05 - time) * 0.2
        );
      },
      updatePoint: (p) => {
        // Match the wave drift (approx -0.133 units per frame at 0.02 time step)
        p.x -= 0.133;
        p.y -= 0.133;

        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.95;
          p.vy *= 0.95;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 12; i++) {
          const angle = (i / 12) * Math.PI * 2;
          particles.push({
            x,
            y,
            age: 1.5,
            vx: Math.cos(angle) * 1.2,
            vy: Math.sin(angle) * 1.2,
          });
        }
        return particles;
      },
    },
    {
      name: "tunnel",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        return (
          Math.sin(40 / (dist + 5) - time * 1.5) * 0.8 +
          Math.sin(Math.atan2(dy, dx) * 5 + time * 0.5) * 0.2
        );
      },
      updatePoint: (p, cx, cy) => {
        const dx = p.x - cx;
        const dy = p.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);

        // Move toward center (inward) - Quicker to match visual flow
        const speed = 0.003 * Math.pow(dist + 5, 1.5);
        if (dist > 1) {
          p.x -= (dx / dist) * speed;
          p.y -= (dy / dist) * speed;
        } else {
          p.age = 0; // Disappear at center
        }

        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.98;
          p.vy *= 0.98;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 20; i++) {
          const angle = (i / 20) * Math.PI * 2;
          particles.push({
            x,
            y,
            age: 1.5,
            vx: Math.cos(angle) * 1.5,
            vy: Math.sin(angle) * 1.5,
          });
        }
        return particles;
      },
    },
    {
      name: "interference",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        const d1 = Math.sqrt(Math.pow(dx - 25, 2) + Math.pow(dy - 10, 2));
        const d2 = Math.sqrt(Math.pow(dx + 25, 2) + Math.pow(dy + 10, 2));
        return (
          (Math.sin(d1 * 0.15 - time * 2) + Math.sin(d2 * 0.15 - time * 2)) *
          0.5
        );
      },
      updatePoint: (p, cx, cy) => {
        // Matching the render function's dx/dy logic for centers
        const c1x = cx + 25 / 0.875;
        const c1y = cy + 10;
        const c2x = cx - 25 / 0.875;
        const c2y = cy - 10;

        const d1x = p.x - c1x;
        const d1y = p.y - c1y;
        const d2x = p.x - c2x;
        const d2y = p.y - c2y;

        const dist1 = Math.sqrt(d1x * d1x + d1y * d1y);
        const dist2 = Math.sqrt(d2x * d2x + d2y * d2y);

        if (dist1 > 0 && dist2 > 0) {
          // Stronger outward push (0.15) to match the wave motion
          p.x += (d1x / dist1 + d2x / dist2) * 0.25;
          p.y += (d1y / dist1 + d2y / dist2) * 0.25;
        }

        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.94;
          p.vy *= 0.94;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 12; i++) {
          const angle = (i / 12) * Math.PI * 2;
          particles.push({
            x,
            y,
            age: 1.5,
            vx: Math.cos(angle) * 1.8,
            vy: Math.sin(angle) * 1.8,
          });
        }
        return particles;
      },
    },
    {
      name: "plasma",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        const v1 = Math.sin(dx * 0.1 + time);
        const v2 = Math.sin(dy * 0.1 + time * 0.5);
        const v3 = Math.sin((dx + dy) * 0.1 + time);
        const v4 = Math.sin(Math.sqrt(dx * dx + dy * dy) * 0.1 + 1);
        return (v1 + v2 + v3 + v4) * 0.25;
      },
      updatePoint: (p) => {
        // Fluid, slow drift
        p.x += Math.cos(p.y * 0.1) * 0.1;
        p.y += Math.sin(p.x * 0.1) * 0.1;
        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.95;
          p.vy *= 0.95;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 12; i++) {
          const angle = (i / 12) * Math.PI * 2;
          particles.push({
            x,
            y,
            age: 1.5,
            vx: Math.cos(angle) * 1.2,
            vy: Math.sin(angle) * 1.2,
          });
        }
        return particles;
      },
    },
    {
      name: "rings",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        const centerIntensity = 12 / (dist + 3);

        // Rotating rings
        const r1 = Math.abs(dist - (30 + Math.sin(time) * 5));
        const r2 = Math.abs(dist - (45 + Math.cos(time * 0.5) * 8));

        const angle = Math.atan2(dy, dx);
        const ring1 =
          (2 / (r1 + 1)) * (Math.sin(angle * 2 + time * 2) * 0.5 + 0.5);
        const ring2 = (2 / (r2 + 1)) * (Math.cos(angle * 3 - time) * 0.5 + 0.5);

        return centerIntensity + ring1 + ring2 - 0.8;
      },
      updatePoint: (p, cx, cy) => {
        const dx = p.x - cx;
        const dy = p.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        // Synchronized with ring rotation (0.03 is a middle ground)
        const angle = Math.atan2(dy, dx) + 0.03;
        p.x = cx + Math.cos(angle) * dist;
        p.y = cy + Math.sin(angle) * dist;
        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.96;
          p.vy *= 0.96;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 20; i++) {
          const angle = (i / 20) * Math.PI * 2;
          particles.push({
            x,
            y,
            age: 1.5,
            vx: Math.cos(angle) * 2,
            vy: Math.sin(angle) * 0.6,
          });
        }
        return particles;
      },
    },
    {
      name: "solar",
      render: (x, y, time, dist, dx, dy, cols, rows) => {
        // Central Sun - pulse it slightly
        const sunPulse = Math.sin(time * 2) * 2;
        const sunIntensity = (12 + sunPulse) / (dist + 3);

        // Planet 1 (Inner, fast)
        const p1x = Math.cos(time * 1.5) * 20;
        const p1y = Math.sin(time * 1.5) * 12;
        const d1 = Math.sqrt(Math.pow(dx - p1x, 2) + Math.pow(dy - p1y, 2));
        const p1Intensity = 8 / (d1 + 2);

        // Planet 2 (Middle, has a tiny moon)
        const p2x = Math.cos(time * 0.8) * 40;
        const p2y = Math.sin(time * 0.8) * 24;
        const d2 = Math.sqrt(Math.pow(dx - p2x, 2) + Math.pow(dy - p2y, 2));

        const m1x = p2x + Math.cos(time * 3) * 6;
        const m1y = p2y + Math.sin(time * 3) * 4;
        const dm1 = Math.sqrt(Math.pow(dx - m1x, 2) + Math.pow(dy - m1y, 2));

        const p2Intensity = 10 / (d2 + 3) + 5 / (dm1 + 1.5);

        // Planet 3 (Outer, slow)
        const p3x = Math.cos(time * 0.4 + 3) * 65;
        const p3y = Math.sin(time * 0.4 + 3) * 38;
        const d3 = Math.sqrt(Math.pow(dx - p3x, 2) + Math.pow(dy - p3y, 2));
        const p3Intensity = 12 / (d3 + 4);

        // Star field background - very subtle
        const stars =
          Math.sin(x * 123.45) * Math.cos(y * 543.21) > 0.99 ? 0.15 : 0;

        return (
          sunIntensity + p2Intensity + p1Intensity + p3Intensity + stars - 1.1
        );
      },
      updatePoint: (p, cx, cy) => {
        const dx = p.x - cx;
        const dy = p.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);

        // Synchronized with planetary orbital rotation (0.02 is time increment)
        const angle = Math.atan2(dy, dx) + 0.02;
        const pull = 0.995; // Slightly less pull for a more stable circular feel
        p.x = cx + Math.cos(angle) * dist * pull;
        p.y = cy + Math.sin(angle) * dist * pull;

        if (p.vx !== undefined && p.vy !== undefined) {
          p.x += p.vx;
          p.y += p.vy;
          p.vx *= 0.94;
          p.vy *= 0.94;
        }
      },
      getClickParticles: (x, y) => {
        const particles = [];
        for (let i = 0; i < 12; i++) {
          const angle = (i / 12) * Math.PI * 2;
          const speed = 1.0 + Math.random();
          particles.push({
            x,
            y,
            age: 1.8,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
          });
        }
        return particles;
      },
    },
  ];

  function initHeroAscii() {
    const canvas = document.getElementById(
      "hero-ascii",
    ) as HTMLPreElement | null;
    const container = document.getElementById("hero-ascii-container");
    if (!canvas || !container) return;

    // Stop any existing animation
    if (frameId) {
      cancelAnimationFrame(frameId);
    }

    const density = " .:-=+*#%@";
    const cols = 200;
    const rows = 100;
    let time = 0;
    let isVisible = true;
    let currentAnimIndex = Math.floor(Math.random() * ANIMATIONS.length);
    let lastSwitchTime = Date.now();

    // Mouse tracking for trail
    let mouseX = -1000;
    let mouseY = -1000;
    const trailPoints: TrailPoint[] = [];
    const trailChars = "@#%*+=-:. ";

    let lastClientX = -1;
    let lastClientY = -1;
    let accumulatedDist = 0;
    const DIST_THRESHOLD = 15; // Lowered threshold to trigger more easily
    let lastTypeSoundTime = 0;
    const MIN_SOUND_INTERVAL = 35; // Allow faster triggering

    // Pause when not in view
    const observer = new IntersectionObserver(
      ([entry]) => {
        isVisible = entry.isIntersecting;
      },
      { threshold: 0 },
    );
    observer.observe(container);

    function addPoint(x: number, y: number, age = 1.0, vx = 0, vy = 0) {
      trailPoints.push({
        x,
        y,
        age,
        char: trailChars[Math.floor(Math.random() * trailChars.length)],
        vx,
        vy,
      });
      if (trailPoints.length > 300) trailPoints.shift();
    }

    container.addEventListener("mousemove", (e) => {
      const rect = canvas.getBoundingClientRect();
      mouseX = ((e.clientX - rect.left) / rect.width) * cols;
      mouseY = ((e.clientY - rect.top) / rect.height) * rows;
      addPoint(mouseX, mouseY);

      if (lastClientX !== -1 && lastClientY !== -1) {
        const dist = Math.hypot(
          e.clientX - lastClientX,
          e.clientY - lastClientY,
        );
        accumulatedDist += dist;

        const now = Date.now();
        if (
          accumulatedDist > DIST_THRESHOLD &&
          now - lastTypeSoundTime > MIN_SOUND_INTERVAL
        ) {
          accumulatedDist = 0;
          lastTypeSoundTime = now;
          const typeSounds = [
            "type_01",
            "type_02",
            "type_03",
            "type_04",
            "type_05",
          ];
          const sound =
            typeSounds[Math.floor(Math.random() * typeSounds.length)];
          // Increased volume slightly to 0.05 to ensure it's audible. Feel free to lower to 0.01 if 0.05 is too loud!
          playSound(sound, 0.15);
        }
      }
      lastClientX = e.clientX;
      lastClientY = e.clientY;
    });

    container.addEventListener("mousedown", (e) => {
      const rect = canvas.getBoundingClientRect();
      const cx = ((e.clientX - rect.left) / rect.width) * cols;
      const cy = ((e.clientY - rect.top) / rect.height) * rows;

      playSound("progress_loop", 0.5);

      const currentAnim = ANIMATIONS[currentAnimIndex];
      const particles = currentAnim.getClickParticles(cx, cy);
      particles.forEach((p) => addPoint(p.x, p.y, p.age, p.vx, p.vy));
    });

    container.addEventListener("mouseleave", () => {
      mouseX = -1000;
      mouseY = -1000;
      lastClientX = -1;
      lastClientY = -1;
      accumulatedDist = 0;
    });

    function render(timestamp: number) {
      if (!isVisible) {
        frameId = requestAnimationFrame(render);
        return;
      }

      // Throttle FPS
      const elapsed = timestamp - lastTime;
      if (elapsed < FRAME_MIN_TIME) {
        frameId = requestAnimationFrame(render);
        return;
      }
      lastTime = timestamp;

      // Check if it's time to switch animation
      if (Date.now() - lastSwitchTime > SWITCH_INTERVAL) {
        currentAnimIndex = (currentAnimIndex + 1) % ANIMATIONS.length;
        lastSwitchTime = Date.now();
      }

      const cx = cols / 2;
      const cy = rows / 2;
      const currentAnim = ANIMATIONS[currentAnimIndex];

      if (currentAnim.prepare) {
        currentAnim.prepare(time, cols, rows);
      }

      // Update trail ages and positions using animation-specific logic
      for (let i = 0; i < trailPoints.length; i++) {
        const point = trailPoints[i];
        point.age -= 0.02;
        currentAnim.updatePoint(point, cx, cy);
      }

      while (trailPoints.length > 0 && trailPoints[0].age <= 0) {
        trailPoints.shift();
      }

      const grid: string[][] = [];
      const radiusSq = 2.5 * 2.5;

      for (let y = 0; y < rows; y++) {
        grid[y] = [];
        for (let x = 0; x < cols; x++) {
          const dx = (x - cx) * 0.875;
          const dy = y - cy;
          const distance = Math.sqrt(dx * dx + dy * dy);

          const animValue = currentAnim.render(
            x,
            y,
            time,
            distance,
            dx,
            dy,
            cols,
            rows,
          );

          // Optimized trail influence
          let trailInfluence = 0;
          for (const point of trailPoints) {
            const adx = Math.abs(x - point.x) * 0.875;
            const ady = Math.abs(y - point.y);

            if (adx < 2.5 && ady < 2.5) {
              const tdistSq = adx * adx + ady * ady;
              if (tdistSq < radiusSq) {
                trailInfluence +=
                  (1 - Math.sqrt(tdistSq) / 2.5) * point.age * 0.5;
              }
            }
          }

          const normalized = (animValue + 1) / 2 + trailInfluence;
          let charIndex = Math.floor(normalized * density.length);
          charIndex = Math.max(0, Math.min(density.length - 1, charIndex));
          grid[y][x] = density[charIndex];
        }
      }

      for (const point of trailPoints) {
        const px = Math.floor(point.x);
        const py = Math.floor(point.y);
        if (px >= 0 && px < cols && py >= 0 && py < rows) {
          if (Math.random() < point.age * 0.5) {
            grid[py][px] = point.char;
          }
        }
      }

      const output = grid.map((row) => row.join("")).join("\n");
      if (canvas) canvas.textContent = output;

      time += 0.02;
      frameId = requestAnimationFrame(render);
    }

    frameId = requestAnimationFrame(render);
    return () => cancelAnimationFrame(frameId);
  }

  // Initialize
  initHeroAscii();
  document.addEventListener("astro:after-swap", initHeroAscii);
</script>
